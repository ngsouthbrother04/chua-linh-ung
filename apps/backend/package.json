{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "openapi:generate:raw": "node swagger.config.cjs",
    "openapi:postprocess": "node scripts/openapi-postprocess.cjs",
    "openapi:generate": "npm run openapi:generate:raw && npm run openapi:postprocess",
    "openapi:check": "node -e \"JSON.parse(require('fs').readFileSync('./openapi.json','utf8')); console.log('openapi.json valid');\"",
    "openapi:lint": "redocly lint --config .redocly.yaml openapi.json",
    "openapi:diff-check": "node scripts/openapi-diff-check.cjs",
    "openapi:diff-check:strict": "node scripts/openapi-diff-check.cjs --strict",
    "tts:validate": "tsx src/scripts/validateTtsConfig.ts",
    "prisma:format": "prisma format --schema prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma",
    "prisma:doctor": "prisma validate --schema prisma/schema.prisma && prisma generate --schema prisma/schema.prisma && prisma migrate status --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:seed": "node -r ts-node/register/transpile-only -r dotenv/config prisma/seed.ts",
    "db:setup": "npm run prisma:migrate:deploy && npm run prisma:generate && npm run prisma:seed"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1017.0",
    "@google-cloud/text-to-speech": "^5.7.0",
    "@google-cloud/translate": "^8.5.0",
    "@types/multer": "^2.1.0",
    "@types/swagger-ui-express": "^4.1.8",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "chua-linh-ung": "file:../..",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "nodemon": "^3.1.11",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.0",
    "@redocly/cli": "^2.25.4",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "prisma": "^6.19.0",
    "supertest": "^7.2.2",
    "swagger-autogen": "^2.23.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
