DATABASE_URL="postgresql://admin:password123@localhost:5433/pho_am_thuc?schema=public"
PAYMENT_CALLBACK_SECRET="replace-with-real-secret"
PAYMENT_CALLBACK_MAX_AGE_SECONDS=300

# ===== MoMo sandbox (real provider) =====
# Lay cac gia tri nay tu trang sandbox cua MoMo.
MOMO_PARTNER_CODE=""
MOMO_ACCESS_KEY=""
MOMO_SECRET_KEY=""
MOMO_GATEWAY_CREATE_URL="https://test-payment.momo.vn/v2/gateway/api/create"
MOMO_REDIRECT_URL="http://localhost:5173/partner-profile"
MOMO_IPN_URL="http://127.0.0.1:3000/api/v1/auth/payment/callback"
MOMO_REQUEST_TYPE="captureWallet"

# ===== TTS core (bat buoc) =====
# REDIS_URL: co gia tri => queue BullMQ, de trong => fallback in-memory
REDIS_URL=""
TTS_WORKER_CONCURRENCY=5
TTS_SUPPORTED_LANGUAGES="vi,en,ko,ja,fr,de,es,pt,ru,zh,th,id,hi,ar,tr"
TTS_PROVIDER="google"

# He thong hien tai chi ho tro local storage cho audio
TTS_STORAGE_PROVIDER="local"

# ===== Audio local storage =====
TTS_LOCAL_AUDIO_DIR="./public/audio"
TTS_PUBLIC_BASE_URL="/audio"

# ===== Google TTS credentials =====
# Dung 1 trong 2 cach:
# 1) GOOGLE_APPLICATION_CREDENTIALS: duong dan file JSON service account
# 2) GOOGLE_TTS_CREDENTIALS_JSON: nhung toan bo JSON vao env
# 3) GOOGLE_TRANSLATE_CREDENTIALS_JSON: tuy chon, override cho translate
GOOGLE_APPLICATION_CREDENTIALS=""
GOOGLE_TTS_CREDENTIALS_JSON=""
GOOGLE_TRANSLATE_CREDENTIALS_JSON=""

# Tuy chon: map language -> voice cu the
# Vi du: {"en":"en-US-Neural2-C","vi":"vi-VN-Standard-A"}
GOOGLE_TTS_VOICE_MAP=""
GOOGLE_TTS_SPEAKING_RATE=1
GOOGLE_TTS_PITCH=0
POI_TRANSLATION_STRICT_MODE="false"

# ===== Cloudinary (upload image POI + Tour) =====
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_POI_FOLDER="phoamthuc/pois"
CLOUDINARY_TOUR_FOLDER="phoamthuc/tours"
CLOUDINARY_MAX_IMAGE_BYTES=5242880
CLOUDINARY_IMAGE_MAX_WIDTH=1600

# true => app fail-fast neu TTS config sai
TTS_STRICT_CONFIG="false"

